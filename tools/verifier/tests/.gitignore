# All .jeff files are generated — recreate with:
#   .venv/bin/python tools/verifier/tests/generate_test_cases.py   (python-generated)
#   tools/verifier/tests/encode_test_cases.sh                       (hand-crafted sources)
**/*.jeff

# .txt files produced by generate_test_cases.py (capnp decode of the generated .jeff)
positive/*.txt
negative/bounds/*.txt
negative/linearity/*.txt
negative/module/missing_version.txt
negative/module/entrypoint_oob.txt
negative/module/no_functions.txt
negative/ordering/*.txt
negative/scoping/*.txt
negative/types/*.txt
